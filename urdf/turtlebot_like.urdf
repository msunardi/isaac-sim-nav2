<?xml version="1.0"?>
<!--
  turtlebot_like.urdf
  ───────────────────
  Differential-drive robot URDF matching the Isaac Sim procedural USD geometry.
  Used by robot_state_publisher on the ROS2 side.

  Frames
  ──────
  base_footprint  → projection of base_link onto the ground plane
  base_link       → chassis centre (z = wheel_radius above ground)
  left_wheel      → left drive wheel axle
  right_wheel     → right drive wheel axle
  front_caster    → front passive caster
  rear_caster     → rear passive caster
  base_scan       → 2-D LiDAR origin
-->
<robot name="turtlebot_like">

  <!-- ────────────────────────────── base_footprint ───────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <!-- wheel centre is 0.033 m above ground -->
    <origin xyz="0 0 0.033" rpy="0 0 0"/>
  </joint>

  <!-- ────────────────────────────── base_link ────────────────────────────── -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.30 0.14"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <box size="0.28 0.30 0.14"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <mass value="2.0"/>
      <!-- box inertia: m/12*(b²+c²) etc. -->
      <inertia
        ixx="0.01346"  ixy="0.0"  ixz="0.0"
        iyy="0.01222"  iyz="0.0"
        izz="0.02225"/>
    </inertial>
  </link>

  <!-- ────────────────────────────── left_wheel ───────────────────────────── -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0.0 0.16 0.0" rpy="-1.5707963 0 0"/>
    <axis   xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
      <material name="dark">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="2.7225e-05"  ixy="0.0"  ixz="0.0"
        iyy="2.7225e-05"  iyz="0.0"
        izz="5.445e-05"/>
    </inertial>
  </link>

  <!-- ────────────────────────────── right_wheel ──────────────────────────── -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0.0 -0.16 0.0" rpy="1.5707963 0 0"/>
    <axis   xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.018"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="2.7225e-05"  ixy="0.0"  ixz="0.0"
        iyy="2.7225e-05"  iyz="0.0"
        izz="5.445e-05"/>
    </inertial>
  </link>

  <!-- ────────────────────────────── front_caster ─────────────────────────── -->
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="front_caster"/>
    <origin xyz="0.10 0.0 -0.018" rpy="0 0 0"/>
  </joint>

  <link name="front_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="light">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="4.5e-06"  ixy="0.0"  ixz="0.0"
        iyy="4.5e-06"  iyz="0.0"
        izz="4.5e-06"/>
    </inertial>
  </link>

  <!-- ────────────────────────────── rear_caster ──────────────────────────── -->
  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="rear_caster"/>
    <origin xyz="-0.10 0.0 -0.018" rpy="0 0 0"/>
  </joint>

  <link name="rear_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="light"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="4.5e-06"  ixy="0.0"  ixz="0.0"
        iyy="4.5e-06"  iyz="0.0"
        izz="4.5e-06"/>
    </inertial>
  </link>

  <!-- ────────────────────────────── base_scan (LiDAR) ────────────────────── -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="base_scan"/>
    <origin xyz="0.0 0.0 0.18" rpy="0 0 0"/>
  </joint>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="1.0e-05"  ixy="0.0"  ixz="0.0"
        iyy="1.0e-05"  iyz="0.0"
        izz="1.0e-05"/>
    </inertial>
  </link>

</robot>
